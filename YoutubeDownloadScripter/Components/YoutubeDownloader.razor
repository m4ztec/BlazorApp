@using RazorConsole.Components
@using Spectre.Console

<Figlet Content="Music Downloader" />
<Newline />

@if (Step == 1)
{
    <Panel Title="Step 1: Select download type">
        <Newline />

        <Select Options="@(new string[] { "Single", "Playlist" })"
                TItem="string"
                Value="Selection"
                Expand="true"
                ValueChanged="OnSelectionChanged" />

        <Newline />
        <Markup Content="Press Enter to continue" Foreground="@Color.Grey58" />
    </Panel>
}

@if (Step == 2)
{
    <Panel Title="Step 2: Enter URL">
        <Newline />

        <TextInput Label="URL:"
                   Value= "Url" 
                   OnSubmit="OnUrlSubmitted" />

        <Newline />
        <Markup Content="Press Enter to continue" Foreground="@Color.Grey58" />
    </Panel>
}

@if (Step == 3)
{
    <Panel Title="Step 3: Summary">
        <Markup Content=$"Type: {Selection}" />
        <Markup Content=$"URL: {Url}" />
    </Panel>

    <Newline />
    <Markup Content="Ready to download..." Foreground="@Color.Green" />
}

@code {
    private int Step { get; set; } = 1;

    private string? Selection { get; set; }
    private string Url { get; set; } = "";

    private void OnSelectionChanged(string value)
    {
        Selection = value;
        NextStep();
    }

    private void OnUrlSubmitted()
    {
        if (string.IsNullOrWhiteSpace(Url))
            return;

        NextStep();
    }

    private void NextStep()
    {
        if (Step < 3)
            Step++;
    }
}